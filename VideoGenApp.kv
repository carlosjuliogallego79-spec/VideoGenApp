#:kivy 2.1.0

<MainScreen>:
    name: 'main'

<VideoScreen>:
    name: 'video'

<TTSScreen>:
    name: 'tts'

<PresentationScreen>:
    name: 'presentation'

<SettingsScreen>:
    name: 'settings'

<Button>:
    background_normal: ''
    background_color: (0.2, 0.6, 1, 1) if not self.text.startswith('<') else (0.5, 0.5, 0.5, 0.5)
    color: (1, 1, 1, 1)
    font_size: '14sp'
    border: (4, 4, 4, 4)

<TextInput>:
    font_size: '14sp'
    padding: (8, 8)

<Label>:
    font_size: '14sp'
    color: (1, 1, 1, 1)

<Switch>:
    active: False

<ProgressBar>:
    max: 100
    value: 0
    background_color: (0.2, 0.2, 0.2, 1)
